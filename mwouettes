#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

SUDO_MODE="auto" # auto|always|never
if [[ "${1-}" == "--sudo" ]]; then
  SUDO_MODE="always"
  shift
elif [[ "${1-}" == "--no-sudo" ]]; then
  SUDO_MODE="never"
  shift
fi

REINSTALL=0
if [[ "${1-}" == "--reinstall" ]]; then
  REINSTALL=1
  shift
fi

if [[ -n "${MWOUETTES_SUDO-}" ]]; then
  case "${MWOUETTES_SUDO}" in
    1|true|yes) SUDO_MODE="always" ;;
    0|false|no) SUDO_MODE="never" ;;
  esac
fi

if [[ ! -x ".venv/bin/python" ]]; then
  python3 -m venv --system-site-packages .venv
fi

if [[ ${REINSTALL} -eq 1 || ! -x ".venv/bin/mwouettes" ]]; then
  if command -v flock >/dev/null 2>&1; then
    exec 9> ".venv/.mwouettes-install.lock"
    flock 9
  fi
  .venv/bin/pip install -e . --no-build-isolation >/dev/null
fi

if [[ $# -eq 0 ]]; then
  set -- --ui
fi

need_sudo=0
if [[ "$SUDO_MODE" == "always" ]]; then
  need_sudo=1
elif [[ "$SUDO_MODE" == "never" ]]; then
  need_sudo=0
else
  for a in "$@"; do
    case "$a" in
      -h|--help|--list-interfaces|--list-audio-devices) ;;
      *) need_sudo=1; break ;;
    esac
  done
fi

if [[ $EUID -ne 0 && $need_sudo -eq 1 ]]; then
  exec sudo -E "$ROOT_DIR/.venv/bin/mwouettes" "$@"
fi

exec "$ROOT_DIR/.venv/bin/mwouettes" "$@"

