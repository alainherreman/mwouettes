#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
if command -v realpath >/dev/null 2>&1; then
  SCRIPT_PATH="$(realpath "$SCRIPT_PATH")"
elif command -v readlink >/dev/null 2>&1; then
  # GNU readlink supports -f; if not, fallback to python.
  SCRIPT_PATH="$(readlink -f "$SCRIPT_PATH" 2>/dev/null || true)"
fi
if [[ -z "$SCRIPT_PATH" || ! -e "$SCRIPT_PATH" ]]; then
  SCRIPT_PATH="$(python3 - <<'PY'
import os, sys
print(os.path.realpath(sys.argv[1]))
PY
"${BASH_SOURCE[0]}")"
fi

ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
cd "$ROOT_DIR"

SUDO_MODE="auto" # auto|always|never
if [[ "${1-}" == "--sudo" ]]; then
  SUDO_MODE="always"
  shift
elif [[ "${1-}" == "--no-sudo" ]]; then
  SUDO_MODE="never"
  shift
fi

REINSTALL=0
if [[ "${1-}" == "--reinstall" ]]; then
  REINSTALL=1
  shift
fi

if [[ -n "${MWOUETTES_SUDO-}" ]]; then
  case "${MWOUETTES_SUDO}" in
    1|true|yes) SUDO_MODE="always" ;;
    0|false|no) SUDO_MODE="never" ;;
  esac
fi

if [[ ! -x ".venv/bin/python" ]]; then
  python3 -m venv --system-site-packages .venv
fi

venv_entry_ok=0
if [[ -x ".venv/bin/mwouettes" ]]; then
  sb="$(head -n 1 .venv/bin/mwouettes 2>/dev/null || true)"
  if [[ "$sb" == "#!/usr/bin/env "* ]]; then
    venv_entry_ok=1
  elif [[ "$sb" == "#!"* ]]; then
    interp="${sb#\#!}"
    if [[ -x "$interp" ]]; then
      venv_entry_ok=1
    fi
  fi
fi

need_install=0
if [[ ${REINSTALL} -eq 1 || $venv_entry_ok -eq 0 ]]; then
  need_install=1
else
  if ! .venv/bin/python -c "import flow_sonify" >/dev/null 2>&1; then
    need_install=1
  fi
fi

if [[ $need_install -eq 1 ]]; then
  if command -v flock >/dev/null 2>&1; then
    exec 9> ".venv/.mwouettes-install.lock"
    flock 9
  fi
  .venv/bin/python -m pip install -e . --no-build-isolation >/dev/null
fi

if [[ $# -eq 0 ]]; then
  set -- --ui
fi

need_sudo=0
if [[ "$SUDO_MODE" == "always" ]]; then
  need_sudo=1
elif [[ "$SUDO_MODE" == "never" ]]; then
  need_sudo=0
else
  for a in "$@"; do
    case "$a" in
      -h|--help|--list-interfaces|--list-audio-devices) ;;
      *) need_sudo=1; break ;;
    esac
  done
fi

if [[ $EUID -ne 0 && $need_sudo -eq 1 ]]; then
  exec sudo -E "$ROOT_DIR/.venv/bin/mwouettes" "$@"
fi

exec "$ROOT_DIR/.venv/bin/mwouettes" "$@"
